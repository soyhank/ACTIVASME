---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ConditionGrid from '../components/ConditionGrid.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SpecialistCard from '../components/SpecialistCard.astro';
import Cta from '../components/Cta.astro';
import { SITE } from '../lib/site';
import { whatsappLink } from '../lib/whatsapp';
import { medicalClinicSchema } from '../lib/schema';

const equipo = (await getCollection('especialistas'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => a.data.orden - b.data.orden)
  .slice(0, 4)
  .map((e) => ({
    nombre: e.data.nombre,
    rol: e.data.rol,
    foto: e.data.foto,
    modalidad: e.data.modalidad,
    href: `/especialistas/${e.id}/`,
  }));

const waHref = whatsappLink();
const title = 'Psicólogos y psiquiatras en Lima';
const description =
  'Centro de salud mental en Lima: terapia psicológica y psiquiatría, presencial y online, para todo el Perú. Atención cálida y basada en evidencia. Agenda por WhatsApp.';

const pilares = [
  { titulo: 'Psicología', href: '/psicologia/', descripcion: 'Psicoterapia individual, de pareja y familiar, evaluaciones y más, con enfoques basados en evidencia.' },
  { titulo: 'Psiquiatría', href: '/psiquiatria/', descripcion: 'Evaluación y tratamiento médico de la salud mental para niños, adolescentes, adultos y adultos mayores.' },
  { titulo: 'Terapia online', href: '/terapia-online/', descripcion: 'El mismo equipo terapéutico, estés donde estés en el Perú o el extranjero.' },
  { titulo: 'Para empresas', href: '/empresas/', descripcion: 'Salud mental ocupacional, telesalud y programas de bienestar laboral.' },
];

const porQue = [
  { t: 'Equipo profesional colegiado', d: 'Psicólogos y médicos psiquiatras con formación clínica y trato humano.' },
  { t: 'Presencial y online', d: 'Elige la modalidad que mejor se adapte a tu vida, en Lima o desde cualquier lugar.' },
  { t: 'Enfoque basado en evidencia', d: 'TCC, ACT, DBT y otros enfoques con respaldo científico, adaptados a ti.' },
  { t: 'Acompañamiento integral', d: 'Coordinamos psicología y psiquiatría para una atención integrada.' },
];
---

<BaseLayout title={title} description={description} canonical="/" jsonld={[medicalClinicSchema()]}>
  <!-- HERO -->
  <section class="home-hero">
    <div class="container-wide home-hero-inner">
      <div class="home-hero-text">
        <p class="hero-eyebrow">Salud mental en Lima · presencial y online</p>
        <h1>Cuida tu salud mental con un equipo que te escucha</h1>
        <p class="hero-lead">
          En {SITE.shortName} acompañamos tu bienestar con <strong>psicología y psiquiatría</strong>,
          de forma presencial en Lima o en línea para todo el Perú. Atención cálida,
          profesional y basada en evidencia.
        </p>
        <div class="hero-actions">
          <a class="btn-accent-lg" href={waHref} target="_blank" rel="noopener">Agenda tu cita por WhatsApp</a>
          <a class="btn-ghost-lg" href="/especialistas/">Conoce al equipo</a>
        </div>
        <p class="hero-slogan">«{SITE.slogan}»</p>
      </div>
      <div class="home-hero-card" aria-hidden="true">
        <div class="hero-badge">
          <span class="hero-badge-num">+8</span>
          <span>años acompañando la salud mental en el Perú</span>
        </div>
        <ul class="hero-points">
          <li>Niños, adolescentes, adultos y adultos mayores</li>
          <li>Citas presenciales y por videollamada</li>
          <li>Psicología + psiquiatría coordinadas</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- PILARES / SERVICIOS DESTACADOS -->
  <section class="home-section">
    <div class="container-wide">
      <h2 class="section-title">¿Cómo podemos ayudarte?</h2>
      <p class="section-sub">Servicios pensados para acompañarte en cada etapa.</p>
      <div class="pillar-grid">
        {pilares.map((p) => <ServiceCard titulo={p.titulo} href={p.href} descripcion={p.descripcion} />)}
      </div>
    </div>
  </section>

  <!-- CONDICIONES -->
  <ConditionGrid />

  <!-- POR QUÉ ACTIVA -->
  <section class="home-section home-why">
    <div class="container-wide">
      <h2 class="section-title">Por qué elegir {SITE.shortName}</h2>
      <div class="why-grid">
        {porQue.map((p) => (
          <div class="why-card">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EQUIPO -->
  {
    equipo.length > 0 && (
      <section class="home-section">
        <div class="container-wide">
          <h2 class="section-title">Nuestro equipo</h2>
          <p class="section-sub">Psicólogos y psiquiatras comprometidos con tu bienestar.</p>
          <div class="team-grid">
            {equipo.map((e) => (
              <SpecialistCard nombre={e.nombre} rol={e.rol} foto={e.foto} href={e.href} modalidad={e.modalidad} />
            ))}
          </div>
          <p class="team-more"><a href="/especialistas/">Ver todo el equipo →</a></p>
        </div>
      </section>
    )
  }

  <Cta />
</BaseLayout>

<style>
  .home-hero {
    background: linear-gradient(165deg, color-mix(in srgb, var(--color-primary-light) 22%, var(--color-bg)), var(--color-bg) 65%);
    padding: 3.5rem 0 3rem;
  }
  .home-hero-inner { display: grid; grid-template-columns: 1.3fr 0.9fr; gap: 2.5rem; align-items: center; }
  .hero-eyebrow { text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.8rem; font-weight: 800; color: var(--color-primary-dark); }
  .home-hero h1 { font-size: clamp(2.1rem, 5vw, 3.3rem); margin-top: 0.7rem; }
  .hero-lead { font-size: clamp(1.05rem, 2vw, 1.25rem); color: var(--color-text-muted); max-width: 56ch; margin-top: 1.1rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.75rem; }
  .btn-accent-lg {
    background: var(--color-accent); color: var(--color-on-accent);
    padding: 0.95rem 1.7rem; border-radius: 999px; font-weight: 800;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .btn-accent-lg:hover { background: var(--color-accent-dark); transform: translateY(-1px); }
  .btn-ghost-lg {
    padding: 0.95rem 1.5rem; border-radius: 999px; font-weight: 700;
    border: 1.5px solid var(--color-primary); color: var(--color-primary-dark);
  }
  .btn-ghost-lg:hover { background: color-mix(in srgb, var(--color-primary-light) 20%, transparent); }
  .hero-slogan { margin-top: 1.5rem; font-style: italic; color: var(--color-primary-dark); font-weight: 600; }

  .home-hero-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); padding: 1.75rem; box-shadow: var(--shadow);
  }
  .hero-badge { display: flex; align-items: center; gap: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border); }
  .hero-badge-num { font-family: var(--font-display); font-size: 2.4rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
  .hero-badge span:last-child { color: var(--color-text-muted); font-size: 0.95rem; }
  .hero-points { list-style: none; margin-top: 1rem; display: grid; gap: 0.6rem; }
  .hero-points li { position: relative; padding-left: 1.6rem; color: var(--color-text); }
  .hero-points li::before { content: '✓'; position: absolute; left: 0; color: var(--color-primary); font-weight: 800; }

  .home-section { padding: 3rem 0; }
  .section-title { font-size: clamp(1.6rem, 3.5vw, 2.2rem); }
  .section-sub { color: var(--color-text-muted); margin: 0.5rem 0 1.75rem; max-width: 60ch; }
  .pillar-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; }

  .home-why { background: color-mix(in srgb, var(--color-primary-light) 12%, var(--color-bg)); }
  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.25rem; }
  .why-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem; }
  .why-check { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 10px; background: var(--color-primary); color: #fff; font-weight: 800; margin-bottom: 0.6rem; }
  .why-card h3 { font-size: 1.05rem; }
  .why-card p { color: var(--color-text-muted); font-size: 0.92rem; margin-top: 0.3rem; }

  .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.25rem; }
  .team-more { margin-top: 1.5rem; }
  .team-more a { color: var(--color-primary-dark); font-weight: 700; }

  @media (max-width: 860px) {
    .home-hero-inner { grid-template-columns: 1fr; }
  }
</style>
