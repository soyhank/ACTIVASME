---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Faq from '../../components/Faq.astro';
import Cta from '../../components/Cta.astro';
import { PSIQUIATRIA } from '../../lib/nav';
import { breadcrumbSchema, faqSchema, serviceSchema } from '../../lib/schema';

const servicios = (await getCollection('servicios'))
  .filter((s) => s.data.pilar === 'psiquiatria' && !s.data.draft)
  .sort((a, b) => a.data.orden - b.data.orden);

const cards = servicios.length
  ? servicios.map((s) => ({ titulo: s.data.h1, href: `/psiquiatria/${s.id}/`, descripcion: s.data.intro }))
  : PSIQUIATRIA.map((s) => ({ titulo: s.titulo, href: s.href, descripcion: undefined }));

const title = 'Psiquiatra en Lima';
const description =
  'Psiquiatría en Lima, presencial y online (telepsiquiatría): TDAH, trastorno bipolar, ansiedad, depresión, sueño y más, para niños, adultos y adultos mayores.';
const url = '/psiquiatria/';
const breadcrumbItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Psiquiatría', href: url },
];

const faq = [
  {
    pregunta: '¿Cuándo conviene acudir a un psiquiatra?',
    respuesta:
      'Cuando los síntomas son intensos o persistentes (ansiedad, depresión, insomnio, cambios de ánimo marcados) o cuando se valora un tratamiento farmacológico. El psiquiatra realiza una evaluación médica y propone un plan individualizado.',
  },
  {
    pregunta: '¿La consulta psiquiátrica puede ser online?',
    respuesta:
      'Sí. La telepsiquiatría permite la evaluación y el seguimiento por videollamada con la misma calidad de atención, ideal si vives fuera de Lima o en el extranjero.',
  },
  {
    pregunta: '¿Tomar medicación significa depender de por vida?',
    respuesta:
      'No necesariamente. La indicación, la dosis y la duración se ajustan a cada caso y se revisan periódicamente junto al paciente. El objetivo siempre es tu bienestar y autonomía.',
  },
];

const jsonld = [
  serviceSchema({ nombre: 'Psiquiatría', descripcion: description, url, tipo: 'MedicalProcedure' }),
  faqSchema(faq),
  breadcrumbSchema(breadcrumbItems),
];
---

<BaseLayout title={title} description={description} canonical={url} jsonld={jsonld}>
  <div class="container-wide pilar-top">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <section class="pilar-hero">
    <div class="container-wide">
      <p class="pilar-eyebrow">Psiquiatría</p>
      <h1>Atención psiquiátrica en Lima y online</h1>
      <p class="pilar-lead">
        Evaluación y tratamiento médico de la salud mental para niños, adolescentes,
        adultos y adultos mayores. Un acompañamiento profesional y respetuoso, presencial
        en Lima o por telepsiquiatría para todo el Perú.
      </p>
    </div>
  </section>

  <section class="container-wide pilar-section">
    <h2>Nuestros servicios de psiquiatría</h2>
    <div class="pilar-grid">
      {cards.map((c) => <ServiceCard titulo={c.titulo} href={c.href} descripcion={c.descripcion} />)}
    </div>
  </section>

  <div class="container-wide">
    <Faq items={faq} />
  </div>

  <Cta />
</BaseLayout>

<style>
  .pilar-top { padding-top: 1.25rem; }
  .pilar-hero { padding: 0.75rem 0 1.5rem; background: linear-gradient(180deg, color-mix(in srgb, var(--color-primary-light) 16%, var(--color-bg)), var(--color-bg)); }
  .pilar-eyebrow { text-transform: uppercase; letter-spacing: 0.1em; font-weight: 800; color: var(--color-primary-dark); font-size: 0.8rem; }
  .pilar-hero h1 { font-size: clamp(1.9rem, 4.5vw, 2.8rem); max-width: 22ch; margin-top: 0.5rem; }
  .pilar-lead { font-size: clamp(1.05rem, 2vw, 1.2rem); color: var(--color-text-muted); max-width: 66ch; margin-top: 1rem; }
  .pilar-section { padding-top: 2rem; }
  .pilar-section h2 { font-size: 1.6rem; margin-bottom: 1.25rem; }
  .pilar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.25rem; }
</style>
