---
import BaseLayout from '../layouts/BaseLayout.astro';
import { whatsappLink } from '../lib/whatsapp';

const waHref = whatsappLink();
const enlaces = [
  { t: 'Inicio', h: '/' },
  { t: 'Psicología', h: '/psicologia/' },
  { t: 'Psiquiatría', h: '/psiquiatria/' },
  { t: 'Especialistas', h: '/especialistas/' },
  { t: 'Terapia online', h: '/terapia-online/' },
  { t: 'Recursos', h: '/recursos/' },
];
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe o fue movida. Te ayudamos a encontrar lo que necesitas en Activa." noindex={true}>
  <section class="nf">
    <div class="container-wide">
      <p class="nf-code">404</p>
      <h1>No encontramos esta página</h1>
      <p class="nf-text">
        Es posible que el enlace haya cambiado o que la página ya no exista. No te preocupes:
        aquí tienes algunos accesos directos para seguir.
      </p>
      <div class="nf-links">
        {enlaces.map((e) => <a href={e.h}>{e.t}</a>)}
      </div>
      <a class="nf-cta" href={waHref} target="_blank" rel="noopener">¿Necesitas ayuda? Escríbenos por WhatsApp</a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding: 4rem 0 5rem; text-align: center; }
  .nf-code { font-family: var(--font-display); font-size: clamp(3rem, 12vw, 6rem); font-weight: 800; color: var(--color-primary-light); line-height: 1; }
  .nf h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); margin-top: 0.5rem; }
  .nf-text { color: var(--color-text-muted); max-width: 52ch; margin: 1rem auto 2rem; }
  .nf-links { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; margin-bottom: 2rem; }
  .nf-links a { padding: 0.55rem 1.1rem; border: 1px solid var(--color-border); border-radius: 999px; font-weight: 600; background: var(--color-surface); }
  .nf-links a:hover { border-color: var(--color-primary-light); color: var(--color-primary-dark); }
  .nf-cta { display: inline-block; background: var(--color-accent); color: var(--color-on-accent); padding: 0.85rem 1.6rem; border-radius: 999px; font-weight: 800; }
  .nf-cta:hover { background: var(--color-accent-dark); }
</style>
