---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Faq from '../components/Faq.astro';
import Cta from '../components/Cta.astro';
import SpecialistCard from '../components/SpecialistCard.astro';
import { whatsappAgendar } from '../lib/whatsapp';
import { breadcrumbSchema, faqSchema, serviceSchema } from '../lib/schema';

interface Especialista {
  nombre: string;
  rol: string;
  foto: string;
  href: string;
  modalidad?: string;
}
interface Relacionado {
  titulo: string;
  href: string;
}

interface Props {
  title: string;
  h1: string;
  description: string;
  intro: string;
  keyword: string;
  modalidad: string;
  enfoques: string[];
  faq: { pregunta: string; respuesta: string }[];
  schemaType: 'MedicalProcedure' | 'MedicalTherapy' | 'Service';
  ultimaRevision: Date;
  pilarLabel: string;
  pilarHref: string;
  url: string;
  especialistas: Especialista[];
  relacionados: Relacionado[];
}

const {
  title, h1, description, intro, modalidad, enfoques, faq,
  schemaType, ultimaRevision, pilarLabel, pilarHref, url,
  especialistas, relacionados,
} = Astro.props;

const breadcrumbItems = [
  { name: 'Inicio', href: '/' },
  { name: pilarLabel, href: pilarHref },
  { name: h1, href: url },
];

const waMensaje = `¡Hola! Quisiera agendar una cita de ${title}.`;

const jsonld = [
  serviceSchema({ nombre: title, descripcion: description, url, tipo: schemaType }),
  faqSchema(faq),
  breadcrumbSchema(breadcrumbItems),
];

const revisado = ultimaRevision.toLocaleDateString('es-PE', {
  year: 'numeric', month: 'long',
});
const modalidadLabel =
  modalidad === 'virtual' ? 'Online' : modalidad === 'presencial' ? 'Presencial' : 'Presencial y online';
---

<BaseLayout title={title} description={description} canonical={url} jsonld={jsonld} whatsappMensaje={waMensaje}>
  <div class="container-wide service-top">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <section class="service-hero">
    <div class="container-wide">
      <p class="service-eyebrow">{pilarLabel}</p>
      <h1>{h1}</h1>
      <p class="service-intro">{intro}</p>
      <div class="service-meta">
        <a class="service-cta" href={whatsappAgendar(title)} target="_blank" rel="noopener">Agenda tu cita</a>
        <span class="service-badge">{modalidadLabel}</span>
        {enfoques.length > 0 && <span class="service-enfoques">Enfoque: {enfoques.join(', ')}</span>}
      </div>
    </div>
  </section>

  <div class="container-wide service-body">
    <article class="prose-activa service-content">
      <slot />
    </article>

    {
      especialistas.length > 0 && (
        <section class="service-specialists">
          <h2>Profesionales que atienden este servicio</h2>
          <div class="spec-grid">
            {especialistas.map((e) => (
              <SpecialistCard nombre={e.nombre} rol={e.rol} foto={e.foto} href={e.href} modalidad={e.modalidad} />
            ))}
          </div>
        </section>
      )
    }

    <Faq items={faq} />

    {
      relacionados.length > 0 && (
        <section class="service-related">
          <h2>Servicios relacionados</h2>
          <ul>
            {relacionados.map((r) => (
              <li><a href={r.href}>{r.titulo}</a></li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="service-review">Última revisión del contenido: {revisado}.</p>
  </div>

  <Cta mensaje={waMensaje} />
</BaseLayout>

<style>
  .service-top { padding-top: 1.25rem; }
  .service-hero { padding: 0.75rem 0 1.5rem; }
  .service-eyebrow {
    text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.78rem;
    font-weight: 800; color: var(--color-primary-dark); margin-bottom: 0.5rem;
  }
  .service-hero h1 { font-size: clamp(1.9rem, 4.5vw, 2.8rem); max-width: 22ch; }
  .service-intro { font-size: clamp(1.05rem, 2vw, 1.2rem); color: var(--color-text-muted); max-width: 64ch; margin-top: 0.9rem; }
  .service-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin-top: 1.4rem; }
  .service-cta {
    background: var(--color-accent); color: var(--color-on-accent);
    padding: 0.8rem 1.5rem; border-radius: 999px; font-weight: 800;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .service-cta:hover { background: var(--color-accent-dark); transform: translateY(-1px); }
  .service-badge {
    font-size: 0.8rem; font-weight: 700; color: var(--color-primary-dark);
    background: color-mix(in srgb, var(--color-primary-light) 28%, var(--color-surface));
    padding: 0.25rem 0.7rem; border-radius: 999px;
  }
  .service-enfoques { font-size: 0.9rem; color: var(--color-text-muted); }

  .service-body { display: block; max-width: 820px; padding-top: 1rem; }
  .service-specialists { margin: 2.5rem 0; }
  .service-specialists h2 { font-size: clamp(1.4rem, 3vw, 1.8rem); margin-bottom: 1.25rem; }
  .spec-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 1rem; }

  .service-related { margin: 2rem 0; }
  .service-related h2 { font-size: 1.3rem; margin-bottom: 0.75rem; }
  .service-related ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .service-related a {
    display: inline-block; padding: 0.5rem 0.9rem; border: 1px solid var(--color-border);
    border-radius: 999px; font-weight: 600; font-size: 0.9rem; background: var(--color-surface);
  }
  .service-related a:hover { border-color: var(--color-primary-light); color: var(--color-primary-dark); }
  .service-review { font-size: 0.82rem; color: var(--color-text-muted); margin-top: 2rem; }
</style>
