---
import { whatsappLink } from '../lib/whatsapp';

interface Props {
  eyebrow?: string;
  titulo: string;
  texto?: string;
  ctaMensaje?: string;
  ctaEtiqueta?: string;
  modalidad?: string;
}
const {
  eyebrow,
  titulo,
  texto,
  ctaMensaje,
  ctaEtiqueta = 'Agenda tu cita',
  modalidad,
} = Astro.props;
const waHref = whatsappLink(ctaMensaje);
---

<section class="hero-internal">
  <div class="container-wide">
    {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
    <h1>{titulo}</h1>
    {texto && <p class="hero-lead">{texto}</p>}
    <div class="hero-actions">
      <a class="hero-cta" href={waHref} target="_blank" rel="noopener">{ctaEtiqueta}</a>
      {modalidad && <span class="hero-modalidad">{modalidad === 'virtual' ? 'Atención online' : modalidad === 'presencial' ? 'Atención presencial' : 'Presencial y online'}</span>}
    </div>
  </div>
</section>

<style>
  .hero-internal {
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-primary-light) 18%, var(--color-bg)), var(--color-bg));
    padding: 2.5rem 0 2rem;
  }
  .hero-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    margin-bottom: 0.6rem;
  }
  .hero-internal h1 { font-size: clamp(1.9rem, 4.5vw, 2.9rem); max-width: 20ch; }
  .hero-lead { font-size: clamp(1.05rem, 2vw, 1.2rem); color: var(--color-text-muted); max-width: 62ch; margin-top: 0.9rem; }
  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin-top: 1.5rem; }
  .hero-cta {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    font-weight: 800;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .hero-cta:hover { background: var(--color-accent-dark); transform: translateY(-1px); }
  .hero-modalidad { font-weight: 600; color: var(--color-primary-dark); font-size: 0.95rem; }
</style>
