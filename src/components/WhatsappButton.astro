---
import { whatsappLink } from '../lib/whatsapp';

interface Props {
  mensaje?: string;
}
const { mensaje } = Astro.props;
const href = whatsappLink(mensaje);
---

<a
  class="wa-float"
  href={href}
  target="_blank"
  rel="noopener"
  aria-label="Escríbenos por WhatsApp para agendar tu cita"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.03h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.36c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.22 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43-.14 0-.31-.01-.48-.01-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z"/>
  </svg>
  <span class="wa-float__label">Agenda por WhatsApp</span>
</a>

<style>
  .wa-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1ebe57;
    color: #fff;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(30, 190, 87, 0.4);
    font-weight: 700;
    font-size: 0.95rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .wa-float:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(30, 190, 87, 0.5);
  }
  .wa-float svg {
    flex: none;
  }
  @media (max-width: 640px) {
    .wa-float__label {
      display: none;
    }
    .wa-float {
      padding: 0.85rem;
    }
  }
</style>
