---
import { MAIN_NAV } from '../lib/nav';
import { whatsappLink } from '../lib/whatsapp';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
const waHref = whatsappLink();
---

<header class="site-header">
  <div class="container-wide header-inner">
    <a href="/" class="brand" aria-label="Activa — Inicio">
      <img src="/logo.png" width="261" height="96" alt="ACTIVA Mental Health & Wellness" />
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Abrir menú"
      data-nav-toggle
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Navegación principal" data-nav>
      <ul class="nav-list">
        {
          MAIN_NAV.map((item) =>
            item.children ? (
              <li class="has-sub">
                <details>
                  <summary class:list={['nav-link', { active: isActive(item.href) }]}>
                    <a href={item.href}>{item.label}</a>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </summary>
                  <ul class="submenu">
                    <li><a href={item.href}><strong>Ver todo: {item.label}</strong></a></li>
                    {item.children.map((c) => (
                      <li><a href={c.href}>{c.titulo}</a></li>
                    ))}
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a class:list={['nav-link', { active: isActive(item.href) }]} href={item.href}>
                  {item.label}
                </a>
              </li>
            ),
          )
        }
        <li class="nav-cta-mobile">
          <a class="btn-accent" href={waHref} target="_blank" rel="noopener">Agenda tu cita</a>
        </li>
      </ul>
    </nav>

    <a class="btn-accent nav-cta" href={waHref} target="_blank" rel="noopener">Agenda tu cita</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    height: 72px;
  }
  .brand img { display: block; height: 44px; width: auto; }

  .primary-nav { margin-left: auto; }
  .nav-list {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.5rem 0.55rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    color: var(--color-text);
    cursor: pointer;
  }
  .nav-link:hover { background: var(--color-bg); color: var(--color-primary-dark); }
  .nav-link.active { color: var(--color-primary-dark); }
  summary.nav-link { list-style: none; }
  summary.nav-link::-webkit-details-marker { display: none; }
  summary.nav-link a { pointer-events: none; }

  .has-sub { position: relative; }
  .has-sub details > summary svg { transition: transform 0.2s ease; }
  .has-sub details[open] > summary svg { transform: rotate(180deg); }

  .submenu {
    list-style: none;
    margin: 0;
    padding: 0.4rem;
  }
  .submenu li a {
    display: block;
    padding: 0.5rem 0.7rem;
    border-radius: 8px;
    font-size: 0.92rem;
    color: var(--color-text);
  }
  .submenu li a:hover { background: var(--color-bg); color: var(--color-primary-dark); }

  .btn-accent {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.55rem 1rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .nav-cta { flex: none; }
  .btn-accent:hover { background: var(--color-accent-dark); transform: translateY(-1px); }
  .nav-cta-mobile { display: none; }

  .nav-toggle { display: none; }

  /* Desktop dropdown */
  @media (min-width: 1101px) {
    .has-sub details > .submenu {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      min-width: 260px;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 14px;
      box-shadow: var(--shadow);
    }
  }

  /* Mobile */
  @media (max-width: 1100px) {
    .nav-cta { display: none; }
    .nav-cta-mobile { display: block; margin-top: 0.5rem; }
    .nav-toggle {
      display: inline-flex;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 0;
      padding: 0.5rem;
      cursor: pointer;
    }
    .nav-toggle span {
      width: 24px;
      height: 2px;
      background: var(--color-text);
      border-radius: 2px;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .nav-toggle[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
    .nav-toggle[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .primary-nav {
      position: fixed;
      inset: 72px 0 auto 0;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      max-height: calc(100dvh - 72px);
      overflow-y: auto;
      padding: 1rem 1.25rem 1.5rem;
      transform: translateY(-110%);
      transition: transform 0.25s ease;
      box-shadow: var(--shadow-lg);
    }
    .primary-nav.open { transform: translateY(0); }
    .nav-list { flex-direction: column; align-items: stretch; gap: 0.15rem; }
    .nav-link { width: 100%; justify-content: space-between; padding: 0.75rem 0.5rem; }
    .submenu { padding-left: 0.5rem; }
  }
</style>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    });
  }
</script>
