---
import { whatsappLink } from '../lib/whatsapp';
import { SITE } from '../lib/site';

interface Props {
  titulo?: string;
  texto?: string;
  mensaje?: string;
  etiqueta?: string;
}
const {
  titulo = 'Da el primer paso hacia tu bienestar',
  texto = 'Conversa con nuestro equipo y agenda tu cita, presencial o en línea. Estamos para acompañarte.',
  mensaje,
  etiqueta = 'Agenda tu cita por WhatsApp',
} = Astro.props;

const href = whatsappLink(mensaje);
---

<section class="cta-band">
  <div class="container-wide cta-inner">
    <div>
      <h2>{titulo}</h2>
      <p>{texto}</p>
    </div>
    <div class="cta-actions">
      <a class="cta-btn" href={href} target="_blank" rel="noopener">{etiqueta}</a>
      <a class="cta-phone" href={`tel:${SITE.phoneE164}`}>{SITE.phoneDisplay}</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: var(--color-on-primary);
    border-radius: var(--radius-lg);
    margin: 3rem auto;
    max-width: 1180px;
  }
  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 2.5rem 2rem;
  }
  .cta-band h2 { color: #fff; font-size: clamp(1.4rem, 3vw, 2rem); }
  .cta-band p { color: #e6f4f2; margin-top: 0.5rem; max-width: 52ch; }
  .cta-actions { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
  .cta-btn {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.9rem 1.6rem;
    border-radius: 999px;
    font-weight: 800;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .cta-btn:hover { background: var(--color-accent-dark); transform: translateY(-1px); }
  .cta-phone { color: #d7eeeb; font-weight: 600; }
  .cta-phone:hover { color: #fff; }
</style>
